<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>

        <!-- H2 embedded (файловый режим) -->
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:file:~/.myfinancy/myfinancy;AUTO_SERVER=TRUE</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>

        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>

        <!-- update — создаёт/обновляет таблицы, не удаляя данные -->
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.show_sql">false</property>

        <!-- Entity mappings -->
        <mapping class="org.example.model.entity.BudgetGroup"/>
        <mapping class="org.example.model.entity.Category"/>
        <mapping class="org.example.model.entity.Transaction"/>
        <mapping class="org.example.model.entity.SavingsGoal"/>
        <mapping class="org.example.model.entity.Debt"/>

    </session-factory>
</hibernate-configuration>
