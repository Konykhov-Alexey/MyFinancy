<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CategoryController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 26 32 18 32;">
                <Label text="Категории" styleClass="page-title"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox spacing="20" style="-fx-padding: 24 32 32 32;">

                <!-- Доходы -->
                <VBox styleClass="card" HBox.hgrow="ALWAYS" minWidth="0">
                    <HBox styleClass="col-header" alignment="CENTER_LEFT" spacing="8">
                        <Label text="↑  ДОХОДЫ" styleClass="section-title income-label"/>
                    </HBox>
                    <Separator/>
                    <VBox fx:id="incomeList"/>
                    <Separator/>
                    <HBox styleClass="add-category-row" spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="incomeNameField"
                                   promptText="Название категории"
                                   HBox.hgrow="ALWAYS"
                                   onAction="#addIncomeCategory"/>
                        <Button text="+ Добавить" styleClass="btn-success" onAction="#addIncomeCategory"/>
                    </HBox>
                </VBox>

                <!-- Расходы -->
                <VBox styleClass="card" HBox.hgrow="ALWAYS" minWidth="0">
                    <HBox styleClass="col-header" alignment="CENTER_LEFT" spacing="8">
                        <Label text="↓  РАСХОДЫ" styleClass="section-title expense-label"/>
                    </HBox>
                    <Separator/>
                    <VBox fx:id="expenseList"/>
                    <Separator/>
                    <HBox styleClass="add-category-row" spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="expenseNameField"
                                   promptText="Название категории"
                                   HBox.hgrow="ALWAYS"
                                   onAction="#addExpenseCategory"/>
                        <Button text="+ Добавить" styleClass="btn-danger" onAction="#addExpenseCategory"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>

</BorderPane>
